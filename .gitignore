# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# security audit reports (may detail live vulnerabilities — keep out of the repo)
.superstack/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright auth session (contains real tokens — never commit)
stellar-toolkit/auth.json

# playwright test results
test-results/

# Claude Code runtime state
.claude/scheduled_tasks.lock

# Stellar Field transient debug artifacts (audit/eval JSONs ARE committed)
apps/field/artifacts/current-screen.png

# duplicate of .claude/skills generated for other agent tools
.agents/

# transient audit/debug scripts and shots
*.tmp.mjs
*.tmp.png
