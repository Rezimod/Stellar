# === Auth ===
NEXT_PUBLIC_PRIVY_APP_ID=           # Privy dashboard → App ID
PRIVY_APP_SECRET=                   # Privy dashboard → App Secret (server-only, never NEXT_PUBLIC_)
# === AI ===
ANTHROPIC_API_KEY=                  # Anthropic console → API Keys

# === Database ===
DATABASE_URL=                       # Neon dashboard → Connection string
SUPABASE_URL=                       # Supabase dashboard → Project URL
SUPABASE_ANON_KEY=                  # Supabase dashboard → anon/public key
NEXT_PUBLIC_SUPABASE_URL=           # Same as SUPABASE_URL (client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Same as SUPABASE_ANON_KEY (client-side)

# === Solana ===
# Network flip: set both of these together for mainnet.
#   devnet  → NEXT_PUBLIC_SOLANA_CLUSTER=devnet        + a devnet RPC
#   mainnet → NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta   + a mainnet RPC (Helius)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet   # devnet | mainnet-beta — drives explorer links, Privy chain, wallet-adapter network
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=         # Client-side RPC (mainnet: your Helius mainnet URL)
FEE_PAYER_PRIVATE_KEY=              # Base58 encoded — covers all gas costs. MAINNET: fund with real SOL + monitor balance.
MERKLE_TREE_ADDRESS=                # Set by: npm run setup:bubblegum (re-run on mainnet for a fresh tree)
COLLECTION_MINT_ADDRESS=            # Set by: npm run setup:bubblegum
STARS_TOKEN_MINT=                   # Set by: npm run setup:token (re-run on mainnet for a fresh mint)

# Proof-of-Observation registry (Anchor program — devnet by default)
OBSERVATION_PROGRAM_ID=             # Defaults to the address baked into the IDL; override for mainnet
OBSERVATION_ORACLE_PRIVATE_KEY=     # Base58 oracle key that signs observation writes; falls back to FEE_PAYER_PRIVATE_KEY on devnet. Set by: npm run setup:observations

# === Public ===
NEXT_PUBLIC_MERCHANT_WALLET=          ntbchmrcwduo298w8uuxfuo1
NEXT_PUBLIC_COLLECTION_MINT_ADDRESS=  # Set by: npm run setup:bubblegum
NEXT_PUBLIC_HELIUS_RPC_URL=         # Helius dashboard — enables DAS API / NFT gallery
NEXT_PUBLIC_APP_URL=https://stellarrclub.vercel.app
NEXT_PUBLIC_FIELD_APK_URL=          # URL to the Stellar Field Android APK (Tether QVAC track). Empty = "Available shortly" on /field.

# === Markets ===
RESOLVER_SECRET=                    # Shared secret for /api/resolver (auto-oracle cron)
ADMIN_SECRET=                       # Shared secret for /api/admin (manual resolver)
NEXT_PUBLIC_ADMIN_WALLET=           # Wallet address allowed to access /admin UI

# === Rate Limiting — Upstash: https://console.upstash.com → Redis → REST API ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Security toggles (production defaults are secure — only flip for rollback) ===
# STELLAR_PAUSED=1                  # Emergency kill-switch: instantly halts all minting/burning/funding
#                                   # (award-stars, mint, observe/log, observe/verify, stars/burn, stars/sync,
#                                   # wallet/fund, club/activate, orders/confirm, redeem-code). Flip in Vercel
#                                   # env — takes effect immediately, no redeploy needed.
# ALLOW_LEGACY_OBSERVE_TOKEN=true   # Re-enable wallet-unbound observation tokens (not recommended)
# ALLOW_UNAUTH_WALLET_FUND=true     # Allow /api/wallet/fund without Privy session (needed for Phantom-only users)

# === Photo Verification ===
# Optional. If set, /api/observe/verify runs Google Vision Web Detection on uploads
# to detect stock / internet-sourced photos. Free tier: 1,000 calls/month.
# If unset, verification falls back to EXIF + cross-wallet hash dedup only.
GOOGLE_VISION_API_KEY=              # Google Cloud Console → APIs & Services → Credentials

# === Rewards ===
REWARD_CODE_MOONLAMP=               # Discount code for Free Moon Lamp tier (250 Stars)
REWARD_CODE_10PCT=                  # Discount code for 10% telescope discount tier (500 Stars)
REWARD_CODE_20PCT=                  # Discount code for 20% telescope discount tier (1000 Stars)

# === X / Twitter Agent (daily auto-posts to @stellarrclub) ===
# Setup: docs/x-agent-setup.md (15 min total)
X_API_KEY=                          # X developer portal → App → Keys and tokens → API Key
X_API_SECRET=                       # Same screen → API Key Secret
X_ACCESS_TOKEN=                     # Same screen → Access Token (must have Read+Write scope)
X_ACCESS_TOKEN_SECRET=              # Same screen → Access Token Secret
X_AGENT_SECRET=                     # openssl rand -hex 32 — signs approve/reject links
CRON_SECRET=                        # openssl rand -hex 32 — gates /api/agent/draft-tweet
OPENAI_API_KEY=                     # Already used by /api/chat (gpt-4o-mini) — agent reuses it

# Telegram approval ping (so you tap "Approve" from your phone)
TELEGRAM_BOT_TOKEN=                 # @BotFather → /newbot → token
TELEGRAM_CHAT_ID=                   # message your bot, then visit api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
